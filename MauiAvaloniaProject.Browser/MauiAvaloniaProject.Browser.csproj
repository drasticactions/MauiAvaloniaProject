<Project Sdk="Microsoft.NET.Sdk.WebAssembly">
	<PropertyGroup>
		<TargetFramework>net11.0-browser</TargetFramework>
		<OutputType>Exe</OutputType>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<Nullable>enable</Nullable>
		<UseMaui>true</UseMaui>
		<RootNamespace>MauiAvaloniaProject</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia" Version="12.0.0-preview2" />
		<PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.0-preview2" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.0-preview2" />
		<PackageReference Include="Avalonia.Browser" Version="12.0.0-preview2" />
		<PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="11.0.0-preview.2.*" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="../../../src/Avalonia.Controls.Maui/Avalonia.Controls.Maui.csproj" />
	  <ProjectReference Include="../MauiAvaloniaProject/MauiAvaloniaProject.csproj" />
	</ItemGroup>
</Project>